<div class="marquee" aria-hidden="true">
  <div class="marquee__track">
    {%- assign items = section.settings.text | split: ',' -%}
    {%- for i in (1..2) -%}
      {%- for item in items -%}
        <span class="marquee__item">
          <span>{{ item | strip }}</span>
          <span>✦</span>
        </span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    { "type": "text", "id": "text", "label": "Items (comma separated)", "default": "Crafted in Paris, Worldwide shipping, Atelier since 1987, Couture standards, Complimentary returns" }
  ],
  "presets": [{ "name": "Marquee" }]
}
{% endschema %}
