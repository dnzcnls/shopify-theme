<header class="site-header">
  <div class="site-header__inner">
    <nav class="site-header__nav" aria-label="Primary">
      {%- for link in linklists.main-menu.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- else -%}
        <a href="{{ routes.collections_url }}">Collections</a>
        <a href="/collections/all">Atelier</a>
        <a href="/pages/about">Maison</a>
        <a href="/pages/journal">Journal</a>
      {%- endfor -%}
    </nav>

    <a href="{{ routes.root_url }}" class="site-header__logo">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: height: 40 }}" alt="{{ shop.name }}" height="40">
      {%- else -%}
        {{ settings.brand_name | default: shop.name }}
      {%- endif -%}
    </a>

    <div class="site-header__actions">
      <a href="{{ routes.search_url }}" class="icon-btn" aria-label="Search">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
      </a>
      <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Account">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-7 8-7s8 3 8 7"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" class="icon-btn" aria-label="Cart">
        <svg viewBox="0 0 24 24"><path d="M6 7h12l-1.2 12.2a2 2 0 0 1-2 1.8H9.2a2 2 0 0 1-2-1.8L6 7z"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/></svg>
        <span class="cart-count" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

{% schema %}
{ "name": "Header", "settings": [] }
{% endschema %}
