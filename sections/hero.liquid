<section class="hero">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', widths: '800,1200,1800,2400' }}
    {%- else -%}
      <img src="{{ 'hero.jpg' | asset_url }}" alt="Maison editorial" loading="eager">
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <span class="h-eyebrow hero__eyebrow">{{ section.settings.eyebrow }}</span>
    <h1 class="hero__title">{{ section.settings.title }}</h1>
    <div class="hero__cta">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_url }}" class="btn btn--light">{{ section.settings.cta_text }}</a>
      {%- endif -%}
      {%- if section.settings.cta_text_2 != blank -%}
        <a href="{{ section.settings.cta_url_2 }}" class="btn btn--ghost" style="color:#fff;border-color:#fff">{{ section.settings.cta_text_2 }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Autumn / Winter Collection" },
    { "type": "textarea", "id": "title", "label": "Title", "default": "A new silhouette of quiet luxury." },
    { "type": "text", "id": "cta_text", "label": "Primary CTA", "default": "Discover" },
    { "type": "url", "id": "cta_url", "label": "Primary URL" },
    { "type": "text", "id": "cta_text_2", "label": "Secondary CTA", "default": "Lookbook" },
    { "type": "url", "id": "cta_url_2", "label": "Secondary URL" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
