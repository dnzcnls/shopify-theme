<div class="auth-wrap">
  <div class="eyebrow-row"><span class="h-rule"></span><span class="h-eyebrow">Account</span><span class="h-rule"></span></div>
  <h1>{{ 'customer.register.title' | t }}</h1>
  <p class="lead">{{ 'customer.register.subtitle' | t }}</p>

  {% form 'create_customer', class: 'auth-form' %}
    {{ form.errors | default_errors }}
    <div>
      <label>{{ 'customer.register.first_name' | t }}</label>
      <input type="text" name="customer[first_name]" required>
    </div>
    <div>
      <label>{{ 'customer.register.last_name' | t }}</label>
      <input type="text" name="customer[last_name]" required>
    </div>
    <div>
      <label>{{ 'customer.register.email' | t }}</label>
      <input type="email" name="customer[email]" required>
    </div>
    <div>
      <label>{{ 'customer.register.password' | t }}</label>
      <input type="password" name="customer[password]" required>
    </div>
    <button type="submit" class="btn">{{ 'customer.register.submit' | t }}</button>
  {% endform %}

  <div class="auth-alt">
    {{ 'customer.register.have_account' | t }} <a href="{{ routes.account_login_url }}" style="border-bottom:1px solid">{{ 'customer.register.sign_in' | t }}</a>
  </div>
</div>
