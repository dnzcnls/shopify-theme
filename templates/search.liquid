<div class="container" style="padding:80px 0">
  <div class="text-center">
    <div class="eyebrow-row"><span class="h-rule"></span><span class="h-eyebrow">Search</span><span class="h-rule"></span></div>
    <h1 class="h-section">The Maison Archive</h1>
    <form action="{{ routes.search_url }}" method="get" style="margin:32px auto 0;max-width:520px;display:flex;gap:12px;border-bottom:1px solid var(--c-ink);padding-bottom:8px">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search" style="flex:1;border:0;font-size:16px;background:transparent">
      <button type="submit" class="btn--link">Search</button>
    </form>
  </div>

  {%- if search.performed -%}
    <p class="text-center" style="margin-top:32px;color:var(--c-muted)">{{ search.results_count }} results for "{{ search.terms }}"</p>
    <div class="product-grid">
      {%- for item in search.results -%}
        {%- if item.object_type == 'product' -%}
          {% render 'product-card', product: item %}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
