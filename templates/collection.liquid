<div class="collection-head">
  <div class="container">
    <div class="eyebrow-row">
      <span class="h-rule"></span>
      <span class="h-eyebrow">Collection</span>
      <span class="h-rule"></span>
    </div>
    <h1 class="h-section">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p style="max-width:640px;margin:24px auto 0;color:var(--c-muted)">{{ collection.description }}</p>
    {%- endif -%}
  </div>
</div>

<div class="container">
  <div class="product-grid">
    {%- for product in collection.products -%}
      {% render 'product-card', product: product %}
    {%- else -%}
      <p>No products found.</p>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <nav class="text-center" style="padding:32px 0 80px">
      {{ paginate | default_pagination }}
    </nav>
  {%- endif -%}
</div>
